# ============================================================
# Ce-Kalan Backend - Variables de Entorno
# ============================================================
# Copia este archivo como .env y configura tus valores

# Servidor
PORT=3001

# Base de Datos MySQL (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cekalan_db

# JWT
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REEMPLAZA_CON_STRING_ALEATORIO_DE_128_CARACTERES
JWT_EXPIRES_IN=7d

# Uploads
UPLOADS_DIR=uploads
