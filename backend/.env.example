# ============================================================
# Ce-Kalan Backend - Variables de Entorno
# ============================================================
# Copia este archivo como .env y configura tus valores

# Servidor
PORT=

# Base de Datos MySQL (XAMPP)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT
JWT_SECRET=cekalan_super_secret_jwt_key_2024_agricola
JWT_EXPIRES_IN=7d

# Uploads
UPLOADS_DIR=uploads

# Credenciales para seed.js (datos de prueba - solo para desarrollo)
# NUNCA uses las mismas credenciales en producción
SEED_ADMIN_NOMBRE=Administrador
SEED_ADMIN_CORREO=admin@tudominio.com
SEED_ADMIN_PASSWORD=CambiaEstaPassword123!
SEED_USER_NOMBRE=Usuario Normal
SEED_USER_CORREO=usuario@tudominio.com
SEED_USER_PASSWORD=CambiaEstaPassword123!
